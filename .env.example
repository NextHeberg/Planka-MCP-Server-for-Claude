# ============================================================
# PLANKA MCP SERVER — Configuration
# ============================================================

# --- Connexion a l'instance Planka ---
# URL complete incluant le schema (http ou https) et le port si non-standard
# Exemples :
#   http://192.168.1.50:3000
#   https://planka.mondomaine.fr
#   http://10.0.0.5:1337
PLANKA_BASE_URL=http://192.168.1.50:3000

# --- Authentification (choisir UNE methode) ---

# Methode 1 — API Key (recommandee, ne perime pas)
# Generer via : POST /api/users/{id}/api-key (outil planka_create_user_api_key)
# Format attendu par Planka : header Authorization: Bearer key_xxxx
PLANKA_API_KEY=

# Methode 2 — Email + Mot de passe (fallback si pas d'API key)
# Le serveur s'authentifiera au demarrage et rafraichira le token JWT en cas de 401
PLANKA_EMAIL=admin@example.com
PLANKA_PASSWORD=

# --- Serveur MCP ---
# Port d'ecoute du serveur HTTP (endpoint /mcp pour Claude.ai)
PORT=3001

# --- TLS / HTTPS (si Planka est derriere un cert auto-signe) ---
# Mettre a "true" uniquement en dev/lab — ne jamais en prod
NODE_TLS_REJECT_UNAUTHORIZED=false

# --- Options avancees ---
# Timeout en ms pour les appels vers Planka (defaut : 30000)
PLANKA_REQUEST_TIMEOUT=30000

# Niveau de log : error | warn | info | debug
LOG_LEVEL=info
